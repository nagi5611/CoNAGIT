# API (presign)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_UPLOAD_BUCKET=

# PoC: skip real auth (never in production)
PRESIGN_REQUIRE_AUTH=0

# Optional: SQLite path for media pipeline rows (created automatically)
MEDIA_PIPELINE_DB_PATH=./data/media-pipeline.db

# CORS for web dev
CORS_ORIGIN=http://localhost:5173

# Presigned URL TTL (seconds)
PRESIGN_EXPIRES_SEC=900

# Worker tuning (thumb validation + CF retries + R2 Cache-Control)
MEDIA_THUMB_MAX_BYTES=26214400
MEDIA_CF_MAX_RETRIES=3
MEDIA_R2_CACHE_CONTROL=public, max-age=86400

# --- SQS worker (`npm run media:sqs-worker`) ---
MEDIA_PIPELINE_SQS_QUEUE_URL=

# Cloudflare Images transform URL: must contain `{source}` replaced with encodeURIComponent(presigned S3 GET URL).
# Example (zone delivery URL pattern — confirm against your Cloudflare dashboard):
# MEDIA_CF_TRANSFORMS_URL_TEMPLATE=https://img.example.com/cdn-cgi/image/width=640,format=webp/{source}

MEDIA_CF_TRANSFORMS_URL_TEMPLATE=

# R2 (S3-compatible API)
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
